KIOSK_URL=file:///opt/pitablet/kiosk/home.html
KIOSK_BROWSER=/usr/bin/chromium
KIOSK_MODE=kiosk
KIOSK_EXTRA_FLAGS=--enable-features=UseOzonePlatform --ozone-platform=wayland --disable-infobars --disable-session-crashed-bubble --disable-features=Translate,MediaRouter,AutofillServerCommunication,OptimizationGuideModelDownloading --check-for-update-interval=31536000 --overscroll-history-navigation=0 --start-maximized
